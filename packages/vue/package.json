{
  "name": "@mark-sorcery/vue",
  "version": "0.4.3",
  "description": "Vue renderer for Mark Sorcery markdown.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build && bun run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@mark-sorcery/markdown-parser": "0.4.2",
    "unified": "11.0.5",
    "unist-util-remove": "4.0.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.0",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "20.8.9",
    "tsdown": "0.21.7",
    "unplugin-vue": "7.1.1",
    "vue": "3.5.31",
    "vue-tsc": "3.2.6"
  },
  "peerDependencies": {
    "typescript": "^5",
    "vue": "^3.5"
  }
}
