{
  "name": "@mark-sorcery/vue",
  "version": "0.3.0",
  "description": "Vue renderer for Mark Sorcery markdown.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build && bun run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@mark-sorcery/markdown-parser": "^0.3.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.4",
    "tsdown": "^0.21.0",
    "unplugin-vue": "^7.1.1",
    "vue": "^3.5.25",
    "vue-tsc": "^3.2.5"
  },
  "peerDependencies": {
    "typescript": "^5",
    "vue": "^3.5"
  }
}
