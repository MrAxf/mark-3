{
  "name": "@mark-sorcery/markdown-parser",
  "version": "0.4.2",
  "description": "Markdown to HAST parser used by Mark Sorcery.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "benchmark": "bun run src/benchmark.ts",
    "build": "tsdown",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build && bun run test",
    "test": "vitest run"
  },
  "dependencies": {
    "rehype-harden": "1.1.8",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "remend": "1.2.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "@types/node": "24.12.0",
    "@types/unist": "3.0.3",
    "tsdown": "0.21.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
