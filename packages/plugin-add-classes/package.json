{
  "name": "@mark-sorcery/plugin-add-classes",
  "version": "0.2.0",
  "description": "Rehype plugin preset for Mark Sorcery that adds CSS classes to elements based on the options provided.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build && bun run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@mark-sorcery/markdown-parser": "workspace:*",
    "@tsconfig/node24": "24.0.4",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.0",
    "tsdown": "0.21.7"
  },
  "peerDependencies": {
    "@mark-sorcery/markdown-parser": "workspace:*",
    "typescript": "^5"
  }
}
