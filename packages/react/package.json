{
  "name": "@mark-sorcery/react",
  "version": "0.1.0",
  "description": "React renderer for Mark Sorcery markdown.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build && bun run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mark-sorcery/markdown-parser": "0.6.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@tsconfig/node24": "24.0.4",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "happy-dom": "20.8.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsdown": "0.21.7"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5"
  }
}
