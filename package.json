{
  "name": "mark-3",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground",
    "docs"
  ],
  "scripts": {
    "build": "bun run build:parser && bun run build:vue",
    "build:parser": "bun run --filter @mark-3/markdown-parser build",
    "build:vue": "bun run --filter @mark-3/vue build",
    "fmt": "bunx oxfmt .",
    "lint": "bunx oxlint .",
    "playground": "bun run --filter playground dev",
    "test": "bun --filter '@mark-3/*' run test"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.10"
}
